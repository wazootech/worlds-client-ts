{
  "name": "@worlds/client",
  "version": "0.0.6",
  "nodeModulesDir": "auto",
  "exports": {
    ".": "./src/mod.ts",
    "./quad-store": "./src/client/quad-store/mod.ts",
    "./search-index": "./src/client/search-index/mod.ts",
    "./search-index/embedding-service": "./src/client/search-index/embedding-service/mod.ts",
    "./search-index/quad-chunker": "./src/client/search-index/quad-chunker/mod.ts",
    "./sparql-engine": "./src/client/sparql-engine/mod.ts",
    "./adapters/libsql": "./src/client/adapters/libsql/mod.ts",
    "./adapters/libsql/n3": "./src/client/adapters/libsql/n3/mod.ts",
    "./adapters/tfjs-universal-sentence-encoder": "./src/client/adapters/tfjs-universal-sentence-encoder/mod.ts",
    "./adapters/comunica": "./src/client/adapters/comunica/mod.ts",
    "./adapters/rdfjs": "./src/client/adapters/rdfjs/mod.ts",
    "./adapters/rdfjs/n3": "./src/client/adapters/rdfjs/n3/mod.ts",
    "./adapters/denokv": "./src/client/adapters/denokv/mod.ts"
  },
  "imports": {
    "ai": "npm:ai@^6.0.188",
    "@ai-sdk/google": "npm:@ai-sdk/google@^3.0.78",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.2.2",
    "@rdfjs/types": "npm:@rdfjs/types@^2.0.1",
    "@libsql/client": "npm:@libsql/client@^0.17.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@tensorflow/tfjs": "npm:@tensorflow/tfjs@^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "npm:@tensorflow/tfjs-backend-wasm@^4.22.0",
    "@types/n3": "npm:@types/n3@1.26.1",
    "n3": "npm:n3@^2.0.3",
    "rdf-canonize": "npm:rdf-canonize@^5.0.0",
    "@langchain/core": "npm:@langchain/core@^1.1.47",
    "@langchain/textsplitters": "npm:@langchain/textsplitters@^1.0.1",
    "zod": "npm:zod@^4.4.3"
  },
  "links": [
    "./vendor/jsonld-context-parser"
  ],
  "exclude": [
    "vendor/jsonld-context-parser/**"
  ],
  "tasks": {
    "download:tfjs-use": "deno run -A ./src/client/adapters/tfjs-universal-sentence-encoder/download-tfjs-use.ts",
    "example:hello-world": "deno -A ./examples/hello-world/main.ts",
    "example:libsql-hello-world": "deno -A ./examples/libsql-hello-world/main.ts",
    "example:libsql-sparql-scale": "deno -A ./examples/libsql-sparql-scale/main.ts",
    "example:libsql-n3-warm-container": "deno -A ./examples/libsql-n3-warm-container/main.ts",
    "example:denokv-hello-world": "deno -A --unstable-kv ./examples/denokv-hello-world/main.ts",
    "example:ai-sdk-hello-world": "deno -A --env ./examples/ai-sdk-hello-world/main.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check",
    "test": "deno test --allow-all --unstable-kv",
    "bench": "deno bench --allow-all --unstable-kv benchmarks/",
    "publish:dry": "deno publish --dry-run --allow-dirty",
    "ci": {
      "description": "Formats, lints, checks, and tests the code",
      "dependencies": [
        "fmt:check",
        "lint",
        "check",
        "test"
      ]
    }
  }
}
