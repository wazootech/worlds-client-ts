{
  "name": "@worlds/client",
  "version": "0.0.1",
  "nodeModulesDir": "auto",
  "exports": {
    ".": "./src/mod.ts",
    "./providers/libsql": "./src/client/providers/libsql/provide-libsql.ts",
    "./providers/tfjs-universal-sentence-encoder": "./src/client/providers/tfjs-universal-sentence-encoder/mod.ts",
    "./providers/comunica": "./src/client/providers/comunica/mod.ts",
    "./providers/rdfjs": "./src/client/providers/rdfjs/mod.ts",
    "./providers/denokv": "./src/client/providers/denokv/provide-denokv.ts"
  },
  "imports": {
    "#/": "./src/",
    "ai": "npm:ai@^6.0.183",
    "@ai-sdk/google": "npm:@ai-sdk/google@^3.0.74",
    "@ai-sdk/groq": "npm:@ai-sdk/groq@^3.0.39",
    "@ai-sdk/ollama": "npm:ai-sdk-ollama@^3.8.4",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^3.0.64",
    "@comunica/query-sparql-rdfjs-lite": "npm:@comunica/query-sparql-rdfjs-lite@^5.2.2",
    "@rdfjs/types": "npm:@rdfjs/types@^2.0.1",
    "@libsql/client": "npm:@libsql/client@^0.17.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/async": "jsr:@std/async@^1.3.0",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@tensorflow-models/universal-sentence-encoder": "npm:@tensorflow-models/universal-sentence-encoder@^1.3.3",
    "@tensorflow/tfjs": "npm:@tensorflow/tfjs@^4.22.0",
    "@tensorflow/tfjs-backend-wasm": "npm:@tensorflow/tfjs-backend-wasm@^4.22.0",
    "@types/n3": "npm:@types/n3@1.26.1",
    "n3": "npm:n3@^2.0.3",
    "sparqlalgebrajs": "npm:sparqlalgebrajs@^5.0.2",
    "rdf-canonize": "npm:rdf-canonize@^5.0.0",
    "@langchain/textsplitters": "npm:@langchain/textsplitters@^1.0.1"
  },
  "links": [
    "./vendor/jsonld-context-parser"
  ],
  "exclude": [
    "vendor/jsonld-context-parser/**",
    ".prior-art"
  ],
  "tasks": {
    "download:tfjs-use": "deno run -A ./scripts/download-tfjs-use.ts",
    "example:hello-world": "deno -A ./examples/hello-world/main.ts",
    "example:libsql-hello-world": "deno -A ./examples/libsql-hello-world/main.ts",
    "example:denokv-hello-world": "deno -A --unstable-kv ./examples/denokv-hello-world/main.ts",
    "example:ai-sdk-hello-world": "deno -A --env ./examples/ai-sdk-hello-world/main.ts",
    "experiment": "deno -A --env scripts/run-experiment.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check",
    "test": "deno test --allow-all --unstable-kv",
    "publish:dry": "deno publish --dry-run --allow-dirty",
    "eval": "deno test --allow-all --unstable-kv evals/",
    "validate:evals": "deno run -A scripts/validate-eval-configs.ts",
    "normalize:search-quality-fixture": "deno run -A scripts/normalize-search-quality-fixture.ts",
    "compare": "deno run -A scripts/compare-evals.ts",
    "ci": {
      "description": "Formats, lints, checks, and tests the code",
      "dependencies": [
        "fmt:check",
        "lint",
        "check",
        "test"
      ]
    }
  }
}
